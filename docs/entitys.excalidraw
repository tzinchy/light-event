    {
      "id": "yAvcqXnfWeBaL08-xgaGd",
      "type": "text",
      "x": -252.51924838504408,
      "y": 1603.06495718729,
      "width": 501.9784904921863,
      "height": 484.0588378906251,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aE",
      "roundness": null,
      "seed": 1706750718,
      "version": 1336,
      "versionNonce": 1757816446,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780347518016,
      "link": null,
      "locked": false,
      "text": "1.формировать пригласительную ссылку\n2.оставлять заявку\n3.просматривать кандидатов (все/только свой\nфилал)\n4.проверять кандидатов\n5.подтверждать кандидатов\n6.добавлять сведения о кандидате\n7.оставлять отзыв о кандидате\n8.добавлять тесты для мерероприятия/заведения\nв целом \n9.менеджер может назначать отвественного внутри\nсистемы \n- за исполнение заявки на меропрития путем\nназначения более мелокого менеджера\n10.удалять менеджеров\n11.передать свою роль (main manager)\n\n\n",
      "fontSize": 20.38142475328948,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1.формировать пригласительную ссылку\n2.оставлять заявку\n3.просматривать кандидатов (все/только свой филал)\n4.проверять кандидатов\n5.подтверждать кандидатов\n6.добавлять сведения о кандидате\n7.оставлять отзыв о кандидате\n8.добавлять тесты для мерероприятия/заведения в целом \n9.менеджер может назначать отвественного внутри системы \n- за исполнение заявки на меропрития путем назначения более мелокого менеджера\n10.удалять менеджеров\n11.передать свою роль (main manager)\n\n\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
