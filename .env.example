# скопируйте в .env и заполните под своё окружение
DATABASE_URL=postgresql+asyncpg://light_event:light_event@localhost:5432/light_event
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=light-event
S3_SECRET_KEY=change-me-minio-secret
S3_BUCKET=light-event
APP_SECRET_KEY=change-me-32-bytes-random
POSTGRES_DB=light_event
POSTGRES_USER=light_event
POSTGRES_PASSWORD=change-me

# Почта для кодов подтверждения.
# Dev: Mailpit из docker-compose (host localhost, port 1025, письма — http://localhost:8025).
# Прод: Brevo (smtp-relay.brevo.com:587, логин/ключ из кабинета, бесплатно 300 писем/день).
# Пустой SMTP_HOST — коды уходят в лог API (ConsoleEmailProvider).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=light-event <no-reply@light-event.local>
SMTP_USE_TLS=false
